{
  "name": "gmail-mcp",
  "version": "1.0.0",
  "description": "Gmail MCP server for Gas Town crew — send emails, manage labels via SMTP/IMAP app password",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gmail-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "imapflow": "^1.0.170",
    "nodemailer": "^8.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^6.4.17",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
